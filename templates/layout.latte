<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{$title}</title>
  <meta name="description" content="{$site['description']}">
  <link rel="stylesheet" href="/static/css/styles.css">
</head>
<body class="bg-slate-950 text-white">
  <header class="border-b border-white/10">
    <nav class="max-w-6xl mx-auto px-4 py-5 flex items-center justify-between">
      <a href="/" class="font-bold">{$site['name']}</a>
      <ul class="flex flex-wrap gap-4 text-sm">
        {foreach $navigation['main'] as $item}
          <li>
            <a href="{$item['url']}" class="hover:text-amber-300">{$item['label']}</a>
          </li>
        {/foreach}
      </ul>
    </nav>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-10">{$content|noescape}</main>

  <footer class="max-w-6xl mx-auto px-4 py-6 border-t border-white/10 text-sm text-white/60">
    <p>{$site['copyright'] ?? ''}</p>
  </footer>
</body>
</html>
