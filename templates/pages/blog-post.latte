<section>
  <p class="text-sm text-amber-300">{$post.tag}</p>
  <h1 class="text-4xl font-bold">{$post.title}</h1>
  <p class="text-sm text-white/70 mt-2">{$post.date} · {$post.reading_time}</p>
  <p class="mt-6">{$post.excerpt}</p>
  <p class="mt-6 text-white/70">This is a static article placeholder generated from fixture content.</p>
</section>
