{
  "name": "app/twelve-factor",
  "description": "FlightPHP prototype based on Twelve-Factor principles",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "flightphp/core": "^3.0",
    "flightphp/container": "^1.0",
    "vlucas/phpdotenv": "^5.6",
    "latte/latte": "^3.0"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.0",
    "slevomat/coding-standard": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "build:static": "php scripts/build-static.php"
  }
}
